# Wrangler local development secrets
# Copy this to .dev.vars and fill in your values
# These are used by `wrangler dev` for local development
# For production, set via `wrangler secret put <NAME>`

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Cloudflare (for D1 HTTP API — still needed until native D1 bindings)
CF_ACCOUNT_ID=8d2df08dac65694aa1c6bf56233a2090
CF_API_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenRouter management key for Light-debit platform inference.
# BYOK provider keys are saved per user and encrypted in Supabase.
OPENROUTER_API_KEY=

# DeepSeek platform key for Galactic Light-debit DeepSeek model routing.
DEEPSEEK_API_KEY=

# Encryption key for user BYOK provider API keys.
BYOK_ENCRYPTION_KEY=

# Platform trust signing key for app version manifests
LIGHT_TRUST_SIGNING_SECRET=

# RunPod GPU
GPU_SUPPORT_ENABLED=false
RUNPOD_API_KEY=
RUNPOD_TEMPLATE_ID=
RUNPOD_BASE_IMAGE=
RUNPOD_CONTAINER_REGISTRY_AUTH_ID=
RUNPOD_ALLOW_SHARED_TEMPLATE_FALLBACK=false
GPU_INTERNAL_SECRET=

# GPU image builds (GitHub Actions + GHCR)
GITHUB_BUILD_REPO=ultralight-run/ultralight-gpu-builds
GITHUB_BUILD_WORKFLOW_ID=gpu-image-build.yml
GITHUB_BUILD_REF=main
GITHUB_ACTIONS_TOKEN=
# Preferred for production instead of GITHUB_ACTIONS_TOKEN:
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_INSTALLATION_ID=
GHCR_IMAGE_NAMESPACE=ghcr.io/ultralight/gpu-apps
GPU_BUILD_CALLBACK_SECRET=
GPU_BUILD_CONTEXT_TTL_SECONDS=3600
GPU_BUILD_LIGHT_PER_MINUTE=
GPU_BASE_IMAGE_PYTHON_CUDA=ghcr.io/ultralight/gpu-bases/python-cuda:py3.11-cuda12.4
GPU_BASE_IMAGE_TORCH_CUDA=ghcr.io/ultralight/gpu-bases/torch-cuda:py3.11-torch2.5-cuda12.4
GPU_BASE_IMAGE_PYTHON_CUDA_SIZE_BYTES=
GPU_BASE_IMAGE_TORCH_CUDA_SIZE_BYTES=

# Supabase Management OAuth
SUPABASE_MGMT_OAUTH_CLIENT_ID=
SUPABASE_MGMT_OAUTH_CLIENT_SECRET=

# Inter-service auth
TIER_CHANGE_SECRET=
GPU_SECRET=
# Signs cross-Agent caller-context headers (X-Galactic-Caller). Required for
# agent-to-agent grant enforcement.
AGENT_CALLER_SECRET=
# Signs routine/sandbox actor tokens (internal execution identities).
# ROUTINE_ACTOR_TOKEN_SECRET falls back to WORKER_SECRET when unset.
ROUTINE_ACTOR_TOKEN_SECRET=
WORKER_SECRET=
# Per-tenant proof for data-worker (R2) access. MUST be identical to the data
# worker's DATA_TENANT_SECRET. Deliberately distinct from WORKER_SECRET (which is
# sandbox-exposed) so a WORKER_SECRET leak alone can't reach another tenant's
# data. Falls back to a dev-only default when unset; set it in prod + staging.
DATA_TENANT_SECRET=
# Signs version trust metadata AND the executed-bundle attestation. FAIL-CLOSED
# in every deployed environment (production AND staging): if neither
# LIGHT_TRUST_SIGNING_SECRET nor TRUST_SIGNING_SECRET is set when ENVIRONMENT is
# anything other than unset/"development"/"test", publishing THROWS (no more
# silent fallback to the Supabase service-role key or a public constant).
# DEPLOY GATE: set this (32+ random bytes) in prod AND staging BEFORE deploying
# this branch, or all publishing/gx.set/upload will 500.
TRUST_SIGNING_SECRET=
# Executed-bundle integrity verification mode: off | observe | enforce.
# Default observe (warn on bundle != signed-attestation). Flip to enforce after
# logs are clean to refuse running a bundle that contradicts its attestation.
EXECUTED_BUNDLE_VERIFY=observe

# Cloudflare Queues (durable execution + event bus) are BINDINGS, not vars —
# provision once per account before the first deploy:
#   wrangler queues create ultralight-exec
#   wrangler queues create ultralight-exec-dlq
#   wrangler queues create ultralight-events
#   wrangler queues create ultralight-events-dlq
#   (and the -staging variants for env.staging)
# Local `wrangler dev` simulates them from wrangler.toml automatically.
