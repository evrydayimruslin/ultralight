# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=ultralight-apps

# OpenRouter (required for Light-debit platform inference; used as a management key
# to provision per-user OpenRouter keys)
OPENROUTER_API_KEY=sk-or-v1-your-key

# BYOK key encryption (required before users can save provider API keys)
BYOK_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Platform trust signing key for app version manifests
LIGHT_TRUST_SIGNING_SECRET=replace-with-random-32-byte-secret

# Deno Deploy (optional, for CLI deployment)
DENO_DEPLOY_TOKEN=ddp_your-token
