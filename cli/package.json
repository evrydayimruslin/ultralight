{
  "name": "galacticconnection",
  "version": "2.3.0",
  "description": "Galactic — local stdio MCP bridge + CLI. Connect any computer-access agent (Claude Code, Claude Desktop, Cursor) to the Galactic platform, with local filesystem tools, plus build/deploy/manage Agents from your shell.",
  "type": "module",
  "bin": {
    "galacticconnection": "bin/ultralight.js",
    "galactic": "bin/ultralight.js"
  },
  "scripts": {
    "build": "echo 'CLI is Deno-native. Use: deno task cli:install'",
    "prepublishOnly": "cp ../skills.md skills.md 2>/dev/null || true",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "galactic",
    "galacticconnection",
    "serverless",
    "cli",
    "mcp",
    "ai",
    "agent",
    "model-context-protocol",
    "mcp-bridge",
    "stdio",
    "tool-discovery",
    "mcp-server"
  ],
  "author": "Galactic",
  "license": "MIT",
  "homepage": "https://connectgalactic.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evrydayimruslin/ultralight.git",
    "directory": "cli"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "mod.ts",
    "api.ts",
    "colors.ts",
    "config.ts",
    "logging.ts",
    "deno.lock",
    "skills.md"
  ]
}
