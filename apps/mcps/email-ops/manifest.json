{
  "name": "email-ops",
  "version": "2.0.0",
  "type": "mcp",
  "entry": { "functions": "index.ts" },
  "description": "Autonomous email agent: connects to hotel mailbox via IMAP, AI classifies and drafts responses in sender's language, queues for admin approval, sends via SMTP. Widget-enabled for desktop Activity tab.",
  "permissions": ["ai:call", "net:fetch", "net:connect"],
  "storage": "d1",
  "env_vars": {
    "IMAP_HOST": { "scope": "per_user", "input": "text", "label": "IMAP host", "required": true, "description": "IMAP server hostname (e.g. imap.titan.email)" },
    "IMAP_PORT": { "scope": "per_user", "input": "number", "label": "IMAP port", "required": true, "description": "IMAP port (993 for TLS)" },
    "IMAP_USER": { "scope": "per_user", "input": "email", "label": "IMAP login", "required": true, "description": "IMAP login (full email address)" },
    "IMAP_PASS": { "scope": "per_user", "input": "password", "label": "IMAP password", "required": true, "description": "IMAP password" },
    "SMTP_HOST": { "scope": "per_user", "input": "text", "label": "SMTP host", "required": true, "description": "SMTP server hostname (e.g. smtp.titan.email)" },
    "SMTP_PORT": { "scope": "per_user", "input": "number", "label": "SMTP port", "required": true, "description": "SMTP port (465 for TLS)" },
    "SMTP_USER": { "scope": "per_user", "input": "email", "label": "SMTP login", "required": true, "description": "SMTP login (full email address)" },
    "SMTP_PASS": { "scope": "per_user", "input": "password", "label": "SMTP password", "required": true, "description": "SMTP password" },
    "BUSINESS_EMAIL": { "scope": "per_user", "input": "email", "label": "From email", "required": true, "description": "From address for outbound emails (e.g. info@rockwoodhotel.com)" },
    "BUSINESS_NAME": { "scope": "per_user", "input": "text", "label": "Business name", "required": true, "description": "Display name for outbound emails (e.g. Rockwood Hotel)" }
  },
  "widgets": [
    {
      "id": "approval_queue",
      "label": "Email Approvals",
      "data_tool": "widget_approval_queue",
      "poll_interval_s": 30
    }
  ],
  "functions": {
    "check_inbox": {
      "description": "Poll the hotel mailbox via IMAP for new emails. Fetches unseen messages, classifies with AI, drafts responses, queues for approval. Can be called manually or via cron.",
      "parameters": []
    },
    "receive_email": {
      "description": "Process an inbound email (called by check_inbox or directly). Classifies intent, drafts response in sender's language, queues for admin approval.",
      "parameters": [
        { "name": "from", "type": "string", "required": false },
        { "name": "to", "type": "string", "required": false },
        { "name": "subject", "type": "string", "required": false },
        { "name": "text", "type": "string", "required": false },
        { "name": "html", "type": "string", "required": false },
        { "name": "message_id", "type": "string", "required": false },
        { "name": "in_reply_to", "type": "string", "required": false }
      ]
    },
    "email_send": {
      "description": "Send an email via SMTP through the hotel's mail server.",
      "parameters": [
        { "name": "to", "type": "string", "required": true },
        { "name": "subject", "type": "string", "required": true },
        { "name": "body", "type": "string", "required": true },
        { "name": "in_reply_to", "type": "string", "required": false }
      ]
    },
    "conversation_act": {
      "description": "Take action on a conversation: send, discard, restore, save_edit, regenerate, followup_draft.",
      "parameters": [
        { "name": "conversation_id", "type": "string", "required": true },
        { "name": "action", "type": "string", "required": true },
        { "name": "body", "type": "string", "required": false },
        { "name": "prompt", "type": "string", "required": false }
      ]
    },
    "conversation_history": {
      "description": "Get full version history for a conversation.",
      "parameters": [
        { "name": "conversation_id", "type": "string", "required": true }
      ]
    },
    "conversations_list": {
      "description": "List conversations by status.",
      "parameters": [
        { "name": "status", "type": "string", "required": false },
        { "name": "limit", "type": "number", "required": false }
      ]
    },
    "conventions_get": {
      "description": "Get business conventions/guidelines by key or category",
      "parameters": [
        { "name": "key", "type": "string", "required": false },
        { "name": "category", "type": "string", "required": false }
      ]
    },
    "conventions_set": {
      "description": "Create or update a business convention.",
      "parameters": [
        { "name": "key", "type": "string", "required": true },
        { "name": "value", "type": "string", "required": true },
        { "name": "category", "type": "string", "required": false }
      ]
    },
    "widget_approval_queue": { "description": "Legacy widget bridge.", "parameters": [] },
    "widget_email_inbox_ui": { "description": "Email approvals deck UI.", "parameters": [] },
    "widget_email_inbox_data": { "description": "Email approvals data.", "parameters": [] },
    "widget_email_faqs_ui": { "description": "FAQ editor widget UI.", "parameters": [] },
    "widget_email_faqs_data": { "description": "FAQ editor data.", "parameters": [] }
  }
}
