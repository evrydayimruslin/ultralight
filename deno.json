{
  "name": "ultralight",
  "version": "0.2.0",
  "exports": "./api/main.ts",
  "tasks": {
    "dev": "cd api && npx wrangler dev",
    "deploy": "cd api && npx wrangler deploy",
    "deploy:staging": "cd api && npx wrangler deploy --env staging",
    "tail": "cd api && npx wrangler tail",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "cli": "deno run --allow-net --allow-read --allow-write --allow-env cli/mod.ts",
    "cli:install": "deno install --allow-net --allow-read --allow-write --allow-env -n ultralight cli/mod.ts",
    "cli:compile": "deno compile --allow-net --allow-read --allow-write --allow-env --output=ultralight cli/mod.ts"
  },
  "imports": {
    "@std/": "https://deno.land/std@0.210.0/",
    "esbuild-wasm": "npm:esbuild",
    "yaml": "npm:yaml",
    "@supabase/supabase-js": "npm:@supabase/supabase-js"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "include": ["api/", "shared/", "web/", "cli/", "sdk/"],
    "rules": {
      "tags": ["recommended"]
    }
  }
}
